# Rust
/target/
**/*.rs.bk
*.pdb
# memeora ships binaries — commit the lockfile for reproducible builds
!Cargo.lock

# Node / TS (dashboard, opencode shim)
node_modules/
dist/
.svelte-kit/
*.tsbuildinfo
# dashboard is documented for pnpm; ignore other package managers' lockfiles
bun.lock
package-lock.json

# memeora runtime data & models
.memeora/
/models/*.onnx
/models/*.bin
*.db
*.db-wal
*.db-shm

# Env & local
.env
.env.local
.DS_Store
*.log

# graphify knowledge-graph output (regenerable)
graphify-out/
