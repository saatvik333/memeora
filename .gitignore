# Rust
/target/
**/*.rs.bk
*.pdb
# memeora ships binaries — commit the lockfile for reproducible builds
!Cargo.lock

# Node / TS (dashboard, opencode shim)
node_modules/
dist/
.svelte-kit/
*.tsbuildinfo
# bun is the TS package manager — commit bun.lock (negate the global *.lock rule),
# ignore other managers' lockfiles
!bun.lock
pnpm-lock.yaml
package-lock.json
yarn.lock

# memeora runtime data & models
.memeora/
/models/*.onnx
/models/*.bin
*.db
*.db-wal
*.db-shm
# fastembed downloads model weights here (repo-root cwd) when bench/tools run
# with real embeddings — large ONNX blobs, never committed
.fastembed_cache/

# benchmark harness inputs (downloaded datasets) + outputs (per-question JSONL);
# regenerable, not repo content — see crates/bench/README.md
/data/
/results/

# Env & local
.env
.env.local
.DS_Store
*.log
