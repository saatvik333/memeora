{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(cargo test:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo run:*)",
      "Bash(cargo add:*)",
      "Bash(cargo nextest:*)",
      "Bash(cargo deny:*)",
      "Bash(cargo install:*)",
      "Bash(rustfmt:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git commit:*)",
      "Bash(git config:*)",
      "Bash(gh run:*)",
      "Bash(gh pr:*)",
      "Bash(scripts/check.sh:*)",
      "Bash(./scripts/check.sh:*)",
      "Bash(bun:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/rustfmt-edited.sh\""
          }
        ]
      }
    ]
  }
}